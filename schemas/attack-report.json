{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Attack Report",
  "description": "Output schema for adversarial ATTACK agent step",
  "type": "object",
  "properties": {
    "verdict": {
      "type": "string",
      "enum": ["ISSUES_FOUND", "CLEAN"]
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "category": {
            "type": "string",
            "enum": ["syntax-and-types", "edge-cases", "concurrency-safety", "adversarial-inputs", "semantic-analysis"]
          },
          "description": { "type": "string" },
          "test_case": { "type": "string" }
        },
        "required": ["category", "description", "test_case"]
      }
    },
    "regressions": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "required": ["verdict"]
}
