{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Decompose Verdict",
  "description": "Output schema for fractal DECOMPOSE agent step",
  "type": "object",
  "properties": {
    "verdict": {
      "type": "string",
      "enum": ["LEAF", "SPLIT"]
    },
    "reason": {
      "type": "string"
    },
    "children": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "slug": { "type": "string" },
          "scope": { "type": "string" },
          "boundaries": { "type": "string" },
          "inputs": { "type": "string" },
          "outputs": { "type": "string" }
        },
        "required": ["slug", "scope"]
      }
    }
  },
  "required": ["verdict"]
}
