{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Merge Report",
  "description": "Output schema for swarm MERGE agent step",
  "type": "object",
  "properties": {
    "merge_strategy": {
      "type": "string",
      "enum": ["fragment-fusion", "winner-take-all", "weighted-blend"]
    },
    "fragments_used": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "from": { "type": "string" },
          "what": { "type": "string" },
          "why": { "type": "string" }
        },
        "required": ["from", "what"]
      }
    },
    "status": {
      "type": "string",
      "enum": ["COMPLETE", "PARTIAL"]
    }
  },
  "required": ["merge_strategy", "status"]
}
